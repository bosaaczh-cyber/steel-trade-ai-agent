# ═══════════════════════════════════════
# Steel Trade AI Agent — Environment Config
# ═══════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Claude API (via OpenAI-compatible endpoint) ---
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_API_URL=https://api.openai.com/v1

# --- Serper API (Google Search) ---
SERPER_API_KEY=your_serper_api_key_here

# --- Aliyun DirectMail ---
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_FROM_ADDRESS=your_verified_email@yourdomain.com
ALIYUN_FROM_ALIAS=YourCompany

# --- Flask ---
FLASK_SECRET=change_this_to_a_random_string

# --- Test ---
TEST_EMAIL=your_own_email@example.com
